
# VARIABLES DE ENTORNO REQUERIDAS

# Ruta al archivo JSON de credenciales de cuenta de servicio de Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/service-account-key.json

# ID del Proyecto de Google Cloud
GOOGLE_CLOUD_PROJECT=tu-proyecto-id


# Local Output Base Path si se quiere usar una ruta local en lugar de GCS
BASE_PATH=ruta/a/tu/directorio_de_salida_local

